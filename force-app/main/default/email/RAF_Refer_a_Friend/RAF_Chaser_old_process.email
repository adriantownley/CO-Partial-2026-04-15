<![CDATA[<div style=""><div style=""><font face="arial">Hi {!Contact.FirstName},</font></div><div style=""><font face="arial"><br></font></div><div style=""><font face="arial">You recently referred your friend to us, but we have been unable to get in touch with them.</font></div><div style=""><font face="arial"><br></font></div><div style=""><font face="arial">If they are still interested in purchasing a policy with us, please can you ask them to call us on <b>01242 808 740</b>.</font></div><div style=""><font face="arial"><br></font></div><div style=""><font face="arial">Kind regards,</font></div><div style=""><font face="arial"><br></font></div><div style=""><font face="arial">{!User.FirstName}</font></div><div style=""><font face="arial">Customer Service Team</font></div><div style=""><font face="arial"><br></font></div><div style=""><font face="arial">E: customersupport@kingsbridge.co.uk</font></div><div style=""><font face="arial">T: 01242 808 740</font></div><div style=""><font face="arial"><br></font></div><div style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt;"><br></div></div>]]></td>
