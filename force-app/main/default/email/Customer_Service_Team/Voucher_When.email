<![CDATA[<div style=""><div style=""><font face="arial">Hi {!Contact.FirstName},</font></div><div style=""><font face="arial"><br></font></div><div style=""><font face="arial">Thank you for contacting Kingsbridge.</font></div><div style=""><font face="arial"><br></font></div><div style=""><font face="arial"><b>All vouchers are sent out via email, 28 days after a policy start date.</b>&nbsp;</font></div><div style=""><font face="arial"><br></font></div><div style=""><font face="arial">Please do not hesitate to get in touch if you have any further queries.</font></div><div style=""><font face="arial"><br></font></div><div style=""><font face="arial">Kind regards,</font></div><div style=""><font face="arial"><br></font></div><div style=""><font face="arial">{!User.FirstName}</font></div><div style=""><font face="arial">Customer Service Team</font></div><div style=""><font face="arial"><br></font></div><div style=""><font face="arial">E: customersupport@kingsbridge.co.uk</font></div><div style=""><font face="arial">T: 01242 808 740</font></div><div style=""><font face="arial"><br></font></div><div style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt;"><br></div></div>]]></td>
