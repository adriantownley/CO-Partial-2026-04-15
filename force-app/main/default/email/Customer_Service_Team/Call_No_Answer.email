<![CDATA[<div style=""><div style=""><div style=""><div style=""><div style=""><font face="arial">Hi {!Contact.FirstName},</font></div><div style=""><font face="arial"><br></font></div><div style=""><font face="arial">I have tried to call back, as requested, but <b>haven't been able to reach you</b>.</font></div><div style=""><font face="arial"><br></font></div><div style=""><font face="arial">Please <b>let me know if there is a good time to try again</b> or alternatively, you can contact me directly on <b>01242 808 740</b>.</font></div><div style=""><font face="arial"><br></font></div><div style=""><font face="arial">Kind regards,</font></div><div style=""><font face="arial"><br></font></div><div style=""><font face="arial">{!User.FirstName}</font></div><div style=""><font face="arial">Customer Service Team</font></div><div style=""><font face="arial"><br></font></div><div style=""><font face="arial">E: customersupport@kingsbridge.co.uk</font></div><div style=""><font face="arial">T: 01242 808 740</font></div></div></div></div></div>]]></td>
