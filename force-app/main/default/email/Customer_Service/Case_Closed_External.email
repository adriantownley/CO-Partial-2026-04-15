<td tEditID="c1r1" style=" background-color:#FFFFFF; bEditID:r3st1; color:#000000; bLabel:main; font-size:12pt; font-family:arial;" aEditID="c1r1" locked="0" >
<![CDATA[<div class="ql-block" data-block-id="block-1ce67c15-0735-4574-91e5-e4e984be9760" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt;">Dear&nbsp;{!Contact.FirstName}</div><div class="ql-block" data-block-id="block-1ce67c15-0735-4574-91e5-e4e984be9760" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt;"><br></div><div class="ql-block" data-block-id="block-1ce67c15-0735-4574-91e5-e4e984be9760" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt;">This is courtesy email to let you know that we have closed your case with reference number {!Case.CaseNumber}.</div><div class="ql-block" data-block-id="block-10ae6db6-4438-482c-97e8-93909537850e" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt;"></div><div class="ql-block" data-block-id="block-f2307f75-9385-4c4f-a631-83feb1cc421e" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt;"><br></div><div class="ql-block" data-block-id="block-f2307f75-9385-4c4f-a631-83feb1cc421e" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt;">If you need to speak to us urgently, please call our phone line on 01242 808 740. Lines are open Monday – Friday between 8am and 5:30pm.</div><div class="ql-block" data-block-id="block-6c99bcd5-230c-4436-8f05-31820559bf51" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt;"></div><div class="ql-block" data-block-id="block-38e7a317-4ed2-4910-af94-95e771c1304a" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt;"><br></div><div class="ql-block" data-block-id="block-38e7a317-4ed2-4910-af94-95e771c1304a" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt;">We would like to thank you for your patience.&nbsp;</div>]]></td>
</tr>
</table>