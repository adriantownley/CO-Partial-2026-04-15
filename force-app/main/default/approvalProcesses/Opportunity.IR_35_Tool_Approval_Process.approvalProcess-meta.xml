<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>false</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
        <field>Owner</field>
        <field>Amount</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>adrian.kingsbridge@kingsbridge.co.uk</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <label>IR 35 Tool Approval</label>
        <name>Approval</name>
    </approvalStep>
    <emailTemplate>Opportunity_Templates/Approval_needed_notification</emailTemplate>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <criteriaItems>
            <field>Opportunity.Number_of_IR_35_Tool_Products__c</field>
            <operation>greaterThan</operation>
            <value>0</value>
        </criteriaItems>
        <criteriaItems>
            <field>Opportunity.RecordType</field>
            <operation>equals</operation>
            <value>Partner Opportunity</value>
        </criteriaItems>
        <criteriaItems>
            <field>Opportunity.IR_35_Tool_Approval_Status__c</field>
            <operation>notEqual</operation>
            <value>Approved</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>IR_35_Tool_to_Approved</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>Ongoing_Approval_Process_to_No</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>Opportunity_Approved_Notification_to_Opportunity_Owner</name>
            <type>Alert</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>false</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>IR_35_Tool_to_Rejected</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>Ongoing_Approval_Process_to_No</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>Opportunity_Rejected_Notification_to_Opportunity_Owner</name>
            <type>Alert</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>Approval_Notification_IR35_Tool</name>
            <type>Alert</type>
        </action>
        <action>
            <name>IR_35_Tool_Approval_to_Submitted</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>Ongoing_Approval_Process_to_Yes</name>
            <type>FieldUpdate</type>
        </action>
    </initialSubmissionActions>
    <label>IR 35 Tool Approval Process</label>
    <nextAutomatedApprover>
        <useApproverFieldOfRecordOwner>false</useApproverFieldOfRecordOwner>
        <userHierarchyField>Manager</userHierarchyField>
    </nextAutomatedApprover>
    <processOrder>3</processOrder>
    <recallActions>
        <action>
            <name>IR_35_Tool_Approval_to_Not_Submitted</name>
            <type>FieldUpdate</type>
        </action>
    </recallActions>
    <recordEditability>AdminOrCurrentApprover</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>
