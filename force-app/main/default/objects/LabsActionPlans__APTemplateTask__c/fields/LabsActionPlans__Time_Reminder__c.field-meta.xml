    <description>Formula to display what time the reminder will be shown. Currently not locale-dependent.</description>
    <externalId>false</externalId>
    <formula>IF(LabsActionPlans__Reminder__c &amp;&amp; !ISBLANK(LabsActionPlans__Minutes_Reminder__c), 
    IF(MOD(FLOOR(VALUE(LabsActionPlans__Minutes_Reminder__c) / 60),12) == 0,&apos;12&apos;,TEXT(MOD(FLOOR(VALUE(LabsActionPlans__Minutes_Reminder__c) / 60),12))) &amp; &apos;:&apos; &amp; IF(MOD(VALUE(LabsActionPlans__Minutes_Reminder__c) ,60)==0,&apos;00&apos;,TEXT(MOD(VALUE(LabsActionPlans__Minutes_Reminder__c) ,60)))+&apos; &apos;+ IF( VALUE(LabsActionPlans__Minutes_Reminder__c)&gt;=720, &apos;PM&apos;,&apos;AM&apos;),

&apos;&apos;)</formula>
    <label>Time Reminder</label>
