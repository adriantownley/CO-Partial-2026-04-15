<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>CV2_CancellationRequireReason</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
$Setup.Kingsbridge_General_Custom_Setting__c.Validation_Rule__c = False,
$RecordType.Name = &apos;Cancellation&apos;,
ISCHANGED(Status),
ISBLANK(tEXT(Cancellation_Reason__c)),
TEXT(Status) = &apos;Closed&apos;
)</errorConditionFormula>
    <errorDisplayField>Cancellation_Reason__c</errorDisplayField>
    <errorMessage>CV1: Please select a Cancellation Reason.</errorMessage>
</ValidationRule>
