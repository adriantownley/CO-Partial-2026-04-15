<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Round_Robin__c</fullName>
    <description>Formula field used to assign Customer and Non-Auto Renewal Opportunities to users in the customer metadata setting Opportunity Round Robins</description>
    <externalId>false</externalId>
    <formula>MOD(VALUE(Opportunity_Number__c),10)+1</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Round Robin</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
