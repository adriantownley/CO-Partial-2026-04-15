<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Date_Email_Template__c</fullName>
    <description>That field converts date/time field for the date field for the email templates cutting out the hour from RN_Action_Date__c</description>
    <externalId>false</externalId>
    <formula>IF( 
ISPICKVAL(Type , &apos;Renewal&apos;),
LPAD(TEXT(DAY(DATEVALUE(Policy_Inception_Date__c) - 1)), 2, &apos;0&apos;) + &apos;/&apos; + LPAD(TEXT(MONTH(DATEVALUE(Policy_Inception_Date__c) - 1)), 2, &apos;0&apos;) + &apos;/&apos; + TEXT(YEAR(DATEVALUE(Policy_Inception_Date__c) - 1)),
NULL
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Date Email Template</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
