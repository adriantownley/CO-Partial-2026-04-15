<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>OV10_PartnerAccountAndOpportunity</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
$Setup.Kingsbridge_General_Custom_Setting__c.Validation_Rule__c = False,
$User.Alias &lt;&gt; &apos;IntUser&apos;,
$User.Alias &lt;&gt; &apos;guest&apos;,
$RecordType.Name &lt;&gt; &apos;Partner Opportunity&apos;,
Account.RecordType.Name = &apos;Partner Accounts&apos;
)</errorConditionFormula>
    <errorMessage>OV10: A Partner Account can only have a Partner Opportunity.</errorMessage>
</ValidationRule>
