        <locationX>50</locationX>
        <locationY>431</locationY>
        <connector>
            <targetReference>Is_New</targetReference>
        </connector>
        <flowName>Source_Set_Source_Count_on_Lead_Auto_launched</flowName>
        <inputAssignments>
            <name>record</name>
            <value>
                <elementReference>$Record</elementReference>
            </value>
        </inputAssignments>
    </subflows>
