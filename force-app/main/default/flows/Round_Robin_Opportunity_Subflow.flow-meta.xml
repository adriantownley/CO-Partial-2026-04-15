    <decisions>
        <name>Does_Loop_Counter_Match_Member_Number</name>
        <label>Does Loop Counter Match Member Number?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Add_1_to_Loop_Counter</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Doesn&apos;t Match</defaultConnectorLabel>
        <rules>
            <name>Counter_Matches_Member_Number</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>LoopCounter</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>NextToAssign</elementReference>
                </rightValue>
            </conditions>
            <connector>
